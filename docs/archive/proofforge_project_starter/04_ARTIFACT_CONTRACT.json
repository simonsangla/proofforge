{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProofForgeArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "category",
    "promise",
    "business_value",
    "status",
    "protection_level",
    "link",
    "capture",
    "tech_stack",
    "date"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "Mini App",
        "Prompt Dojo",
        "Prompt Forge",
        "Code Pattern",
        "Best Practice",
        "UI Pattern",
        "Product Experiment",
        "Data Tool",
        "Playbook",
        "Micro Utility"
      ]
    },
    "promise": {
      "type": "string",
      "minLength": 1
    },
    "business_value": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "concept",
        "live_demo",
        "replica",
        "private_engine",
        "archived"
      ]
    },
    "protection_level": {
      "type": "string",
      "enum": [
        "public",
        "limited",
        "private"
      ]
    },
    "link": {
      "type": "string",
      "minLength": 1
    },
    "capture": {
      "type": "string",
      "minLength": 1
    },
    "tech_stack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "date": {
      "type": "string",
      "pattern": "^\\\\d{4}-\\\\d{2}-\\\\d{2}$"
    }
  }
}